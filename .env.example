# ═══════════════════════════════════════════════════════════════════
# Insurance RAG — Superadmin Back Office
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
# Points to the main app's Postgres container via the shared Docker
# network. The hostname is the main app's db SERVICE name, which by
# default is prefixed with the project directory name:
#
#   <main-app-folder>-db-1
#
# For example, if your main app lives in a folder called
# "insurance-rag", the container is "insurance-rag-db-1".
#
# Run `docker ps` to confirm the exact container name, then use it
# as the hostname below.
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@client-backend-db-1:5432/insurance_rag
DATABASE_URL_SYNC=postgresql://postgres:postgres@client-backend-db-1:5432/insurance_rag

# ── Security ──────────────────────────────────────────────────────
# MUST match the SECRET_KEY from the main app's .env
SECRET_KEY=ins-rag-9f2k4j7m3x8b1v5n6p0w2q4r7t9y1u3

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ── Server ────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
DEBUG=true
